# ============================================================
#  ОБЯЗАТЕЛЬНО ЗАПОЛНИТЬ
# ============================================================

# Токен бота от @BotFather
BOT_TOKEN=

# Telegram ID администраторов через запятую (узнать: @userinfobot)
ADMIN_IDS=

# ============================================================
#  НЕОБЯЗАТЕЛЬНО (есть значения по умолчанию)
# ============================================================

# Префикс для имён контейнеров/сети/тома. Меняйте ТОЛЬКО если на сервере
# уже есть стек с таким именем. Изолирует бота от других ботов на сервере.
COMPOSE_PROJECT_NAME=tg-bug-opros

# Таймаут бездействия сессии, в секундах (по умолчанию 600 = 10 мин)
TIMEOUT_SECONDS=600

# Максимальный размер одного скриншота в байтах (по умолчанию 10 МБ)
MAX_SCREENSHOT_BYTES=10485760

# REDIS_URL и DATA_DIR задаются автоматически в docker-compose.yml — не трогайте.
